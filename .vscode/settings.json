{
  "python.defaultInterpreterPath": "apps/api/.venv/bin/python",
  "python.analysis.extraPaths": ["apps/api"],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["apps/api/tests"],
  "[python]": { "editor.defaultFormatter": "ms-python.black-formatter", "editor.formatOnSave": true },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "editor.codeActionsOnSave": { "source.organizeImports": "explicit" },
  "files.exclude": { "**/__pycache__": true, "**/.next": true, "**/node_modules": true }
}
